{
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19"
  },
  "scripts": {
    "build:css": "tailwindcss -i input.css -o static/output.css --content \"./Templates/**/*.html\" \"./**/*.html\"",
    "watch:css": "tailwindcss -i input.css -o static/output.css --watch --content \"./Templates/**/*.html\" \"./**/*.html\""
  }
}
